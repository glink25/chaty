{
	"name": "@glink25/chaty",
	"private": false,
	"version": "0.1.0",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/assistant/index.d.ts",
			"import": "./dist/assistant/index.js"
		},
		"./providers": {
			"types": "./dist/providers/index.d.ts",
			"import": "./dist/providers/index.js"
		}
	},
	"scripts": {
		"dev": "vite --host",
		"build": "pnpm run lint && vite build",
		"build:lib": "tsc -b && vite build --config vite.lib.config.ts",
		"prepublishOnly": "pnpm run build:lib",
		"analyze": "ANALYZE=true vite build",
		"lint": "tsc -b && biome check --diagnostic-level error",
		"preview": "vite preview --host --port 5173",
		"check": "biome check --write"
	},
	"peerDependencies": {
		"jsonrepair": "^3.13.3",
		"zod": "^4.1.11"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-slot": "^1.2.3",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify/tailwind4": "^1.0.6",
		"@tailwindcss/vite": "^4.1.12",
		"@types/node": "^24.3.1",
		"@types/react": "^19.1.10",
		"@types/react-dom": "^19.1.7",
		"@vitejs/plugin-react": "^6.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"idb": "^8.0.3",
		"jsonrepair": "^3.13.3",
		"lucide-react": "^0.544.0",
		"marked": "^18.0.4",
		"radix-ui": "^1.4.3",
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "^4.1.12",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.3.8",
		"typescript": "~5.8.3",
		"unplugin-info": "^1.2.4",
		"vite": "^8.0.8",
		"vite-bundle-analyzer": "^1.2.3",
		"vite-plugin-dts": "^5.0.2",
		"vite-plugin-svgr": "^4.5.0",
		"zod": "^4.1.11",
		"zustand": "^5.0.8",
		"zustand-indexeddb": "^0.1.1"
	}
}
